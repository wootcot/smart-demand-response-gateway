# Firmware (ESP32 / ESP-IDF v6.0.1) Makefile
#
# Uses the activation script generated by the ESP-IDF VS Code extension (eim).
# This ensures the exact same environment the extension uses for builds.

SHELL  := /bin/bash
PORT   ?= /dev/tty.usbserial-0001

# Path to the activation script generated by the ESP-IDF extension installer.
# Override with: make build IDF_ACTIVATE=/path/to/your/activate_idf.sh
IDF_ACTIVATE ?= $(HOME)/.espressif/tools/activate_idf_v6.0.1.sh

ifeq ($(wildcard $(IDF_ACTIVATE)),)
  $(error ESP-IDF activation script not found at $(IDF_ACTIVATE). Install ESP-IDF via the VS Code extension or set IDF_ACTIVATE.)
endif

# Source the activation script then invoke idf.py (which is aliased inside the script,
# but aliases don't work in non-interactive shells — so we call the Python + idf.py directly).
IDF_PYTHON := $(HOME)/.espressif/tools/python/v6.0.1/venv/bin/python3
IDF_PY     := $(HOME)/.espressif/v6.0.1/esp-idf/tools/idf.py

# Source the activation script for PATH and env vars, then run idf.py via python
IDF = source $(IDF_ACTIVATE) >/dev/null 2>&1 && $(IDF_PYTHON) $(IDF_PY)

# --- Targets ---
.DEFAULT_GOAL := help

.PHONY: help build flash monitor menuconfig clean flash-monitor reconfigure

help: ## Show this help message
	@echo ""
	@echo "Firmware (ESP32) targets:"
	@echo ""
	@grep -E '^[a-zA-Z0-9_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-25s\033[0m %s\n", $$1, $$2}'
	@echo ""
	@echo "Environment:"
	@echo "  IDF_ACTIVATE = $(IDF_ACTIVATE)"
	@echo "  PORT         = $(PORT)"
	@echo ""

build: ## Build firmware
	$(IDF) build

reconfigure: ## Re-run CMake configure (regenerates compile_commands.json)
	$(IDF) reconfigure

flash: ## Flash firmware to ESP32
	$(IDF) -p $(PORT) flash

monitor: ## Open serial monitor
	$(IDF) -p $(PORT) monitor

menuconfig: ## Open ESP-IDF menuconfig
	$(IDF) menuconfig

clean: ## Remove build artifacts (full clean)
	$(IDF) fullclean

flash-monitor: ## Flash and immediately open monitor
	$(IDF) -p $(PORT) flash monitor
