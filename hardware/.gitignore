# KiCad lock files
*.lck

# KiCad backup files
*-bak
*-bak.*
*.bak
_autosave-*

# KiCad temp files
*.tmp
*~

# Footprint cache
fp-info-cache

# Netlist files (regenerated from schematic)
*.net

# DRC/ERC reports (regenerated on demand)
*.rpt

# Loose fabrication outputs (only the zip is committed)
fabrication/*.gbr
fabrication/*.gbl
fabrication/*.gtl
fabrication/*.gbs
fabrication/*.gts
fabrication/*.gbo
fabrication/*.gto
fabrication/*.gbp
fabrication/*.gtp
fabrication/*.gba
fabrication/*.gta
fabrication/*.gm1
fabrication/*.gbrjob
fabrication/*.drl
!fabrication/*.zip
