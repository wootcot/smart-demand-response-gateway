	(title_block
		(title "Relay Driver - Opto-Isolated Load Switching")
		(date "2025-05-20")
		(rev "1.0")
		(company "Ailsh Giri")
		(comment 1 "PC817 optocoupler + NPN transistor + relay")
		(comment 2 "Galvanic isolation between 3.3V logic and 230V AC")
		(comment 3 "Creepage greater than 6mm per IEC 60950-1")
	)
	(lib_symbols)
	(text "OPTO-ISOLATED RELAY DRIVER\nESP32 GPIO (3.3V) to R5 (330 Ohm) to PC817 LED to GND\nPC817 phototransistor to R6 (1K) to Q1 Base\nQ1 Collector to Relay Coil (SRD-05VDC) to VCC_5V\nD4 flyback protection across coil\nD5 TVS across relay contacts for arc suppression"
