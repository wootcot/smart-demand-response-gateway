		(date "2025-05-20")
		(rev "1.0")
		(company "Ailsh Giri")
		(comment 1 "ESP32-WROOM-32 with WiFi/BT")
		(comment 2 "I2C to ADS1115 (GPIO22 SCL, GPIO21 SDA), GPIO for relay control")
		(comment 3 "UART for debug/OTA, EN/BOOT for programming")
	)
	(lib_symbols)
	(text "ESP32 MODULE\nGPIO22 (SCL): I2C Clock to ADS1115\nGPIO21 (SDA): I2C Data to ADS1115\nGPIO4: Relay command output\nGPIO2: WiFi status LED\nGPIO1 (TX0): UART TX\nGPIO3 (RX0): UART RX\nEN: 10K pull-up + reset button\nGPIO0: Boot mode select"
